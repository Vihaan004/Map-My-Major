{
  "version": 2,
  "name": "map-my-major",
  "buildCommand": "cd app/frontend && npm install && npm run build",
  "outputDirectory": "app/frontend/dist",
  "installCommand": "cd app/frontend && npm install",
  "functions": {
    "api/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    {
      "src": "/api/users/(.*)",
      "dest": "/api/users.js?path=$1"
    },
    {
      "src": "/api/maps/(.*)",
      "dest": "/api/maps.js?path=$1"
    },
    {
      "src": "/api/maps",
      "dest": "/api/maps.js"
    },
    {
      "src": "/api/semesters/(.*)",
      "dest": "/api/semesters.js?path=$1"
    },
    {
      "src": "/api/classes/(.*)",
      "dest": "/api/classes.js?path=$1"
    },
    {
      "src": "/api/requirements/(.*)",
      "dest": "/api/requirements.js?path=$1"
    },
    {
      "src": "/api/requirements",
      "dest": "/api/requirements.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
